# Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# API Base URL (for future backend integration)
VITE_API_BASE_URL=http://localhost:8000/api

# Anthropic API Key (for AI parsing - Phase 3)
VITE_ANTHROPIC_API_KEY=your_api_key_here

# Feature Flags
VITE_ENABLE_AI_PARSING=false
VITE_ENABLE_IMAGE_UPLOAD=false
VITE_ENABLE_PDF_EXPORT=false

# Analytics (optional)
VITE_GA_TRACKING_ID=
VITE_SENTRY_DSN=

# App Configuration
VITE_APP_NAME="Block Shear Analyzer"
VITE_APP_VERSION="1.0.0"
